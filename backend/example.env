# ChoreCraft Backend Environment Configuration
#
# Copy this file to .env and fill in the values for your local environment.

# --- Database Configuration ---
# The full connection string for your PostgreSQL database.
# Format: postgres://[user]:[password]@[host]:[port]/[dbname]?sslmode=[sslmode]
# Example: postgres://chorecraft_user:strong_password@localhost:5432/chorecraft_db?sslmode=disable
DATABASE_URL="postgres://user:password@localhost:5432/chorecraft?sslmode=disable"

# --- Server Configuration ---
# The port on which the Go REST API server will listen for incoming requests.
# Default is 8080 if not specified.
PORT="8080"

# --- AI Service Configuration ---
# The backend uses Google Gemini for resolving task emojis.
# You need a valid Gemini API key to enable asynchronous icon mapping.

# Your Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"
